 178:application/chassis/chassis.c **** /**
 179:application/chassis/chassis.c ****  * @brief Ķ«Īń«Śµ»ÅõĖ¬ĶĮ«µ»éńöĄµ£║ńÜäĶŠōÕć║,µŁŻĶ┐ÉÕŖ©ÕŁ”Ķ¦Żń«Ś
 180:application/chassis/chassis.c ****  *        ńö©Õ«ÅĶ┐øĶĪīķóäµø┐µŹóÕćÅÕ░ÅÕ╝ĆķöĆ,Ķ┐ÉÕŖ©Ķ¦Żń«ŚÕģĘõĮōĶ┐ćń©ŗÕÅéĶĆāµĢÖń©ŗ
 181:application/chassis/chassis.c ****  */
 182:application/chassis/chassis.c **** static void MecanumCalculate()
 183:application/chassis/chassis.c **** {
 184:application/chassis/chassis.c ****     switch (chassis_config->wheel_type)
 185:application/chassis/chassis.c ****     {
 186:application/chassis/chassis.c ****     case MECANUM_WHEEL:
 187:application/chassis/chassis.c ****         // ķ║”ĶĮ«Ķ¦Żń«ŚķĆåĶ┐ÉÕŖ©ÕŁ”µ©ĪÕ×ŗ
 188:application/chassis/chassis.c ****         vt_lf = -chassis_vx - chassis_vy - chassis_cmd_recv.wz * lf_center;
 189:application/chassis/chassis.c ****         vt_rf = -chassis_vx + chassis_vy - chassis_cmd_recv.wz * rf_center;
 190:application/chassis/chassis.c ****         vt_lb = chassis_vx - chassis_vy - chassis_cmd_recv.wz * lb_center;
 191:application/chassis/chassis.c ****         vt_rb = chassis_vx + chassis_vy - chassis_cmd_recv.wz * rb_center;
