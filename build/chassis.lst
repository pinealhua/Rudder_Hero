 182:application/chassis/chassis.c **** static void MecanumCalculate()
 183:application/chassis/chassis.c **** {
 184:application/chassis/chassis.c ****     switch (chassis_config->wheel_type)
 185:application/chassis/chassis.c ****     {
 186:application/chassis/chassis.c ****     case MECANUM_WHEEL:
 187:application/chassis/chassis.c ****         // é؛¦è½®è§£ç®—é€†è؟گهٹ¨ه­¦و¨،ه‍‹
 188:application/chassis/chassis.c ****         vt_lf = -chassis_vx - chassis_vy - chassis_cmd_recv.wz * lf_center;
 189:application/chassis/chassis.c ****         vt_rf = -chassis_vx + chassis_vy - chassis_cmd_recv.wz * rf_center;
 190:application/chassis/chassis.c ****         vt_lb = chassis_vx - chassis_vy - chassis_cmd_recv.wz * lb_center;
 191:application/chassis/chassis.c ****         vt_rb = chassis_vx + chassis_vy - chassis_cmd_recv.wz * rb_center;
 192:application/chassis/chassis.c ****         break;
 193:application/chassis/chassis.c ****     case OMNI_WHEEL:
 194:application/chassis/chassis.c ****         // ه…¨هگ‘è½®è§£ç®—é€†è؟گهٹ¨ه­¦و¨،ه‍‹
 195:application/chassis/chassis.c ****         vt_lf = -sqrtf(2) / 2.0f * chassis_vx - sqrtf(2) / 2.0f * chassis_vy - chassis_cmd_recv.wz 
 196:application/chassis/chassis.c ****         vt_rf = -sqrtf(2) / 2.0f * chassis_vx + sqrtf(2) / 2.0f * chassis_vy - chassis_cmd_recv.wz 
 197:application/chassis/chassis.c ****         vt_lb = sqrtf(2) / 2.0f * chassis_vx + sqrtf(2) / 2.0f * chassis_vy - chassis_cmd_recv.wz *
 198:application/chassis/chassis.c ****         vt_rb = sqrtf(2) / 2.0f * chassis_vx - sqrtf(2) / 2.0f * chassis_vy - chassis_cmd_recv.wz *
